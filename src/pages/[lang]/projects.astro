---
import Layout from '@layouts/Layout.astro';
import Container from '@components/container.astro';
import Cta from '@components/cta.astro';
import { defaultLang, isLang, type Lang, languages, t } from '../../i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang },
    props: { lang }
  }));
}

const langParam = Astro.params.lang ?? defaultLang;
const lang: Lang = isLang(langParam) ? langParam : defaultLang;

const projects = [
  {
    name: 'MotionTrack',
    desc: t(lang, 'projectMotionTrackDescFull'),
    tags: ['Computer Vision', 'PyTorch', 'Video Analysis'],
    status: t(lang, 'statusPrototype'),
    statusClass: 'bg-brand-500/10 text-brand-400 border border-brand-500/20'
  },
  {
    name: 'CoachLens',
    desc: t(lang, 'projectCoachLensDescFull'),
    tags: ['Performance Analytics', 'NLP', 'Time Series'],
    status: t(lang, 'statusInResearch'),
    statusClass: 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
  },
  {
    name: 'SportsGraph',
    desc: t(lang, 'projectSportsGraphDescFull'),
    tags: ['Knowledge Graph', 'Data Science', 'Graph ML'],
    status: t(lang, 'statusExperimental'),
    statusClass: 'bg-red-500/10 text-red-400 border border-red-500/20'
  },
  {
    name: 'LiveStats',
    desc: t(lang, 'projectLiveStatsDescFull'),
    tags: ['Data Engineering', 'Streaming', 'API'],
    status: t(lang, 'statusInternalTool'),
    statusClass: 'bg-white/[0.05] text-slate-400 border border-white/[0.08]'
  }
];
---

<Layout lang={lang}>
  <Container>
    <div class="mt-16 max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-400 mb-3">
        {t(lang, 'navProjects')}
      </p>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white">
        {t(lang, 'featuredProjectsSubHeader')}
      </h1>
      <p class="mt-5 text-lg text-slate-400 leading-relaxed max-w-xl">
        {t(lang, 'newsNoNews')}
      </p>
    </div>
    <div class="mt-8 flex flex-wrap gap-2">
      {
        [
          { label: t(lang, 'statusPrototype'), cls: 'bg-brand-500/10 text-brand-400 border border-brand-500/20' },
          { label: t(lang, 'statusInResearch'), cls: 'bg-blue-500/10 text-blue-400 border border-blue-500/20' },
          { label: t(lang, 'statusExperimental'), cls: 'bg-red-500/10 text-red-400 border border-red-500/20' },
          { label: t(lang, 'statusInternalTool'), cls: 'bg-white/[0.05] text-slate-400 border border-white/[0.08]' }
        ].map((s) => <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-semibold', s.cls]}>{s.label}</span>)
      }
    </div>
    <div class="mt-12 grid sm:grid-cols-2 gap-5">
      {
        projects.map((p) => (
          <div
            class="group relative rounded-2xl border border-white/[0.07] p-6 transition hover:-translate-y-0.5 hover:border-white/[0.13]"
            style="background: linear-gradient(135deg, #0F1728 0%, #0A0F1C 100%);"
          >
            <div class="flex items-start justify-between gap-3 mb-3">
              <h2 class="text-lg font-semibold text-white">{p.name}</h2>
              <span class:list={['shrink-0 rounded-full px-2.5 py-0.5 text-[11px] font-semibold', p.statusClass]}>
                {p.status}
              </span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed mb-5">{p.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map((tag) => (
                <span class="rounded-md border border-white/[0.07] bg-white/[0.04] px-2 py-0.5 text-[11px] font-medium text-slate-500">
                  {tag}
                </span>
              ))}
            </div>
            <div
              class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition"
              style="box-shadow: inset 0 0 0 1px rgba(132,204,22,0.12);"
              aria-hidden="true"
            />
          </div>
        ))
      }
    </div>
    <div class="mt-12 rounded-2xl border border-dashed border-white/[0.10] bg-white/[0.02] px-8 py-10 text-center">
      <p class="text-sm font-medium text-slate-300">
        {t(lang, 'projectsComingSoon')}
      </p>
      <p class="text-sm text-slate-500 mt-1">
        {t(lang, 'projectsFollowGithub')}
      </p>
      <a
        href="https://github.com/Athletics-Intelligence-AGH"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/[0.12] bg-white/[0.04] px-5 py-2 text-sm font-medium text-slate-300 transition hover:border-white/[0.20] hover:text-white hover:bg-white/[0.08]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        GitHub
      </a>
    </div>

    <Cta lang={lang} />
  </Container>
</Layout>
