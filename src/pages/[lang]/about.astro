---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import Container from '@components/container.astro';
import Cta from '@components/cta.astro';
import { defaultLang, isLang, type Lang, languages, t } from '../../i18n';
import type { TeamMemberData } from '../../content.config.ts';
import { canBeDisplayed } from '../../utils.ts';

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang },
    props: { lang }
  }));
}

const langParam = Astro.params.lang ?? defaultLang;
const lang: Lang = isLang(langParam) ? langParam : defaultLang;

const byOrderThenName = (a: { data: TeamMemberData }, b: { data: TeamMemberData }) => {
  const ao = a.data.order ?? 9999;
  const bo = b.data.order ?? 9999;
  if (ao !== bo) return ao - bo;
  return a.data.name.localeCompare(b.data.name);
};

const supervisorMembers = (
  await getCollection('supervisors', ({ data }) => canBeDisplayed(data.draft, data.publishDate))
).sort(byOrderThenName);

const managementMembers = (
  await getCollection('management', ({ data }) => canBeDisplayed(data.draft, data.publishDate))
).sort(byOrderThenName);
---

<Layout lang={lang}>
  <Container>
    <!-- Page header -->
    <div class="mt-16 max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-400 mb-3">
        {t(lang, 'navAbout')}
      </p>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white">
        {t(lang, 'aboutSubHeader')}
      </h1>
      <p class="mt-5 text-lg text-slate-400 leading-relaxed max-w-xl">
        {t(lang, 'aboutLongerDescription')}
      </p>
    </div>

    <!-- Supervisors -->
    <div class="mt-20">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-8">
        {t(lang, 'supervisorsTeamGroup')}
      </h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {
          supervisorMembers.map(({ data: { name, avatar, title } }) => (
            <div
              class="group rounded-2xl border border-white/[0.07] p-5 transition hover:-translate-y-0.5 hover:border-white/[0.13]"
              style="background: linear-gradient(135deg, #0F1728 0%, #0A0F1C 100%);"
            >
              <div class="w-14 h-14 rounded-xl overflow-hidden bg-dark-300 mb-4">
                <Image
                  src={avatar.src}
                  alt={avatar.alt}
                  width={56}
                  height={56}
                  class="w-full h-full object-cover object-center"
                />
              </div>
              <h3 class="text-sm font-semibold text-white leading-snug">{name}</h3>
              <p class="text-xs text-slate-500 mt-1">{t(lang, title)}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Leadership -->
    <div class="mt-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-500 mb-8">
        {t(lang, 'managementTeamGroup')}
      </h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {
          managementMembers.map(({ data: { avatar, name, title } }) => (
            <div
              class="group rounded-2xl border border-white/[0.07] p-5 transition hover:-translate-y-0.5 hover:border-white/[0.13]"
              style="background: linear-gradient(135deg, #0F1728 0%, #0A0F1C 100%);"
            >
              <div class="w-14 h-14 rounded-xl overflow-hidden bg-dark-300 mb-4">
                <Image
                  src={avatar.src}
                  alt={avatar.alt}
                  width={56}
                  height={56}
                  class="w-full h-full object-cover object-center"
                />
              </div>
              <h3 class="text-sm font-semibold text-white leading-snug">{name}</h3>
              <p class="text-xs text-slate-500 mt-1">{t(lang, title)}</p>
            </div>
          ))
        }
      </div>
    </div>

    <Cta lang={lang} />
  </Container>
</Layout>
