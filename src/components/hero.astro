---
import { t, type Lang } from '../i18n';
import HeroScene from './HeroScene';

const { lang } = Astro.props as { lang: Lang };
---

<HeroScene
  client:only="react"
  lang={lang}
  heroHeader={t(lang, 'heroHeader')}
  heroCtaPrimary={t(lang, 'heroCtaPrimary')}
  heroCtaSecondary={t(lang, 'heroCtaSecondary')}
/>
