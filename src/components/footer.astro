---
import { t, type Lang } from '../i18n';

const { lang } = Astro.props as { lang: Lang };
---

<footer class="mt-24 border-t border-white/[0.06] bg-dark-50">
  <div class="max-w-screen-xl mx-auto px-5 py-14">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a
          href={`/${lang}/`}
          class="inline-flex items-center gap-2.5 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500/50 rounded-lg"
        >
          <svg
            class="w-6 h-6 text-brand-500"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.25" stroke-opacity="0.35"></circle>
            <ellipse cx="12" cy="12" rx="9.5" ry="4" stroke="currentColor" stroke-width="1.25" stroke-opacity="0.60"
            ></ellipse>
            <ellipse cx="12" cy="12" rx="4" ry="9.5" stroke="currentColor" stroke-width="1.25" stroke-opacity="0.60"
            ></ellipse>
            <circle cx="12" cy="2.5" r="1.5" fill="currentColor"></circle>
            <circle cx="21.5" cy="12" r="1.25" fill="currentColor" fill-opacity="0.65"></circle>
            <circle cx="12" cy="21.5" r="1.1" fill="currentColor" fill-opacity="0.45"></circle>
          </svg>
          <span class="text-sm font-semibold tracking-tight text-white">
            AGH <span class="text-brand-400">Athletics</span><span class="text-slate-500"> Intelligence</span>
          </span>
        </a>
        <p class="mt-3 text-sm text-slate-500 leading-relaxed max-w-xs">
          Implementing AI solutions into sport — from performance analytics to fan experience.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-4">Navigation</h3>
        <ul class="space-y-2.5">
          <li><a href={`/${lang}/`} class="text-sm text-slate-500 transition hover:text-white">Home</a></li>
          <li>
            <a href={`/${lang}/about`} class="text-sm text-slate-500 transition hover:text-white"
              >{t(lang, 'navAbout')}</a>
          </li>
          <li>
            <a href={`/${lang}/projects`} class="text-sm text-slate-500 transition hover:text-white"
              >{t(lang, 'navProjects')}</a>
          </li>
          <li>
            <a href={`/${lang}/contact`} class="text-sm text-slate-500 transition hover:text-white"
              >{t(lang, 'navContact')}</a>
          </li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-4">Connect</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="mailto:athletic@agh.edu.pl"
              class="inline-flex items-center gap-2 text-sm text-slate-500 transition hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-4 h-4 shrink-0 text-slate-600"
                aria-hidden="true"
              >
                <path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z"></path>
                <path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z"
                ></path>
              </svg>
              athletic@agh.edu.pl
            </a>
          </li>
          <li>
            <a
              href="https://github.com/Athletics-Intelligence-AGH"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 transition hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-4 h-4 shrink-0 text-slate-600"
                aria-hidden="true"
              >
                <path
                  d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-600">
        &copy; {new Date().getFullYear()} AGH Athletics Intelligence. All rights reserved.
      </p>
      <p class="text-xs text-slate-600">AGH University of Science and Technology, Kraków</p>
    </div>
  </div>
</footer>
