---
import { t, type Lang } from '../i18n';

const { lang } = Astro.props as { lang: Lang };

const projects = [
  {
    name: 'MotionTrack',
    desc: t(lang, 'projectMotionTrackDesc'),
    tags: ['Computer Vision', 'PyTorch'],
    status: t(lang, 'statusPrototype'),
    statusClass: 'bg-brand-500/10 text-brand-400 border border-brand-500/20'
  },
  {
    name: 'CoachLens',
    desc: t(lang, 'projectCoachLensDesc'),
    tags: ['Performance', 'NLP'],
    status: t(lang, 'statusInResearch'),
    statusClass: 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
  },
  {
    name: 'SportsGraph',
    desc: t(lang, 'projectSportsGraphDesc'),
    tags: ['Knowledge Graph', 'Data Science'],
    status: t(lang, 'statusExperimental'),
    statusClass: 'bg-red-500/10 text-red-400 border border-red-500/20'
  },
  {
    name: 'LiveStats',
    desc: t(lang, 'projectLiveStatsDesc'),
    tags: ['Data Engineering', 'Streaming'],
    status: t(lang, 'statusInternalTool'),
    statusClass: 'bg-white/[0.05] text-slate-400 border border-white/[0.08]'
  }
];
---

<section class="py-20 border-t border-white/[0.07]">
  <div class="max-w-2xl">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-400 mb-3">
      {t(lang, 'featuredProjectsHeader')}
    </p>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white">
      {t(lang, 'featuredProjectsSubHeader')}
    </h2>
  </div>

  <div class="mt-12 grid sm:grid-cols-2 gap-5">
    {
      projects.map((p) => (
        <div
          class="group relative rounded-2xl border border-white/[0.07] bg-dark-100 p-6 transition hover:-translate-y-0.5 hover:border-white/[0.13]"
          style="background: linear-gradient(135deg, #0F1728 0%, #0A0F1C 100%);"
        >
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-white">{p.name}</h3>
            <span class:list={['shrink-0 rounded-full px-2.5 py-0.5 text-[11px] font-semibold', p.statusClass]}>
              {p.status}
            </span>
          </div>
          <p class="text-sm text-slate-500 leading-relaxed mb-4">{p.desc}</p>
          <div class="flex flex-wrap gap-1.5">
            {p.tags.map((tag) => (
              <span class="rounded-md border border-white/[0.07] bg-white/[0.04] px-2 py-0.5 text-[11px] font-medium text-slate-500">
                {tag}
              </span>
            ))}
          </div>
          <div
            class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition"
            style="box-shadow: inset 0 0 0 1px rgba(132,204,22,0.12);"
            aria-hidden="true"
          />
        </div>
      ))
    }
  </div>
</section>
