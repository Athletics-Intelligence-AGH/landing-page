---
import { t, type Lang } from '../i18n';

const { lang } = Astro.props as { lang: Lang };
---

<div
  class="relative mt-24 overflow-hidden rounded-2xl px-8 py-16 md:px-16 md:py-20"
  style="background: linear-gradient(135deg, #0D1525 0%, #070B14 50%, #0A1A08 100%);"
>
  <!-- Grid overlay -->
  <div class="cta-grid pointer-events-none absolute inset-0 opacity-[0.045]" aria-hidden="true"></div>

  <!-- Corner glow blobs -->
  <div
    class="pointer-events-none absolute -top-32 -right-32 w-80 h-80 rounded-full"
    style="background: radial-gradient(circle, rgba(132,204,22,0.18) 0%, transparent 65%);"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-24 -left-24 w-64 h-64 rounded-full"
    style="background: radial-gradient(circle, rgba(56,189,248,0.10) 0%, transparent 65%);"
    aria-hidden="true"
  >
  </div>

  <!-- Hairline border -->
  <div class="pointer-events-none absolute inset-0 rounded-2xl border border-white/[0.08]" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-2xl text-center">
    <!-- Eyebrow -->
    <div
      class="inline-flex items-center gap-2 rounded-full border border-brand-500/25 bg-brand-500/[0.08] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-400 mb-6"
    >
      <span class="block w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse" aria-hidden="true"></span>
      Join the team
    </div>

    <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white text-balance">
      {t(lang, 'joinCtaHeader')}
    </h2>

    <p class="mt-4 text-base md:text-lg text-slate-400 max-w-xl mx-auto">
      {t(lang, 'joinCtaDescription')}
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-400 hover:-translate-y-px hover:shadow-xl hover:shadow-brand-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
      >
        {t(lang, 'joinButton')}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
      <a
        href={`/${lang}/about`}
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-white/70 transition hover:bg-white/[0.09] hover:text-white hover:-translate-y-px focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/20 focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
      >
        Meet the team
      </a>
    </div>
  </div>
</div>

<style>
  .cta-grid {
    background-image:
      linear-gradient(rgba(163, 255, 18, 1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(163, 255, 18, 1) 1px, transparent 1px);
    background-size: 44px 44px;
  }
</style>
